# Environment: dev | test | prod
SEVEN_ENV=dev

# Database
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=
DB_NAME=sevencms

# Site
SITE_NAME=SevenCMS
BASE_URL=http://localhost:8085

# Vite — set to true during local development (npm run dev), false in production
VITE_DEV=false

# Cache — driver: file | redis
CACHE_DRIVER=file
CACHE_TTL=3600

# Redis (used only when CACHE_DRIVER=redis)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PREFIX=seven:
